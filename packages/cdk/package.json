{
  "name": "cdk",
  "version": "0.1.0",
  "scripts": {
    "cdk-synth": "cdk synth  --output ../../cdk.out --quiet --app \"tsx -- bin/${CDK_APP_NAME}.ts\"",
    "cdk-deploy": "cdk deploy ${CDK_STACK_NAME} --app \"tsx -- bin/${CDK_APP_NAME}.ts\" --ci true --require-approval ${REQUIRE_APPROVAL}",
    "lint": "eslint  --max-warnings 0 --fix --config ../../eslint.config.mjs ."
  },
  "dependencies": {
    "@nhsdigital/eps-cdk-constructs": "^1.7.1",
    "aws-cdk-lib": "^2.250.0",
    "cdk-nag": "^2.38.1",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "aws-cdk": "^2.1119.0",
    "tsx": "^4.21.0"
  }
}
